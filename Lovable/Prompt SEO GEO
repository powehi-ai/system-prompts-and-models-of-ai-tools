### 4. Données structurées JSON-LD

#### Organization + Service (Homepage)
```json
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "...",
  "url": "...",
  "logo": "...",
  "sameAs": ["LinkedIn", "Twitter"]
}
```

#### Article (Blog)
```json
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "...",
  "description": "...",
  "image": "...",
  "datePublished": "...",
  "dateModified": "...",
  "author": { "@type": "Organization", "name": "...", "url": "..." },
  "publisher": { "@type": "Organization", "name": "...", "logo": {...} },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "canonical_url" },
  "about": [
    { "@type": "Thing", "name": "AI Act", "sameAs": "url_wikipedia_ou_officiel" },
    { "@type": "Thing", "name": "Artificial Intelligence", "sameAs": "url_wikipedia" }
  ],
  "speakable": { "@type": "SpeakableSpecification", "cssSelector": ["h1", "article > section:first-of-type p"] },
  "inLanguage": "fr"
}
```

#### FAQ (optionnel, par article ou page)
```json
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "...", "acceptedAnswer": { "@type": "Answer", "text": "..." } }
  ]
}
```

